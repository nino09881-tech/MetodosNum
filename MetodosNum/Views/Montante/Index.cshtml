<style>
    body {
        font-family: Arial;
        padding: 20px;
        background: #f0f2f5;
    }

    h1 {
        text-align: center;
    }

    h2 {
        color: #FF5722;
    }

    .card {
        background: white;
        padding: 15px;
        margin-bottom: 15px;
        border-radius: 10px;
        box-shadow: 0px 4px 8px rgba(0,0,0,0.1);
    }

    .btn {
        background: #FF5722;
        color: white;
        padding: 10px;
        border: none;
        border-radius: 5px;
    }
</style>

<h1>Método de Montante (Bareiss)</h1>

<div class="card">
    <h2>📘 Teoría</h2>
    <p>
        El método de Montante es una variante de la eliminación gaussiana que evita
        fracciones intermedias utilizando una fórmula basada en determinantes.
    </p>

    <p>
        Permite resolver sistemas de ecuaciones de forma exacta y estable.
    </p>
</div>

<div class="card">
    <h2>📊 Algoritmo</h2>
    <ol>
        <li>Formar matriz aumentada</li>
        <li>Seleccionar pivote</li>
        <li>Aplicar fórmula de Montante</li>
        <li>Actualizar pivote anterior</li>
        <li>Obtener solución</li>
    </ol>
</div>

<div class="card">
    <h2>📈 Ejemplo</h2>

    <p>
        2x + 3y = 5 <br />
        4x + y = 6
    </p>

    <p>
        Aplicando Montante se obtiene:
    </p>

    <p>
        x = 1.3 <br />
        y = 0.8
    </p>
</div>

<div class="card">
    <h2>💻 Calculadora</h2>

    <form method="post">

        <p>Matriz A</p>

        <input name="a11" placeholder="a11" />
        <input name="a12" placeholder="a12" />
        <br />

        <input name="a21" placeholder="a21" />
        <input name="a22" placeholder="a22" />

        <br /><br />

        <p>Vector B</p>

        <input name="b1" placeholder="b1" />
        <input name="b2" placeholder="b2" />

        <br /><br />

        <button type="submit" class="btn">Resolver</button>
    </form>

    @if (ViewBag.Resultado != null)
    {
        <h3>@ViewBag.Resultado</h3>
    }
</div>